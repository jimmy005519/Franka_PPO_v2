<?xml version="1.0"?>
<robot name="think_shell_free">
  <!-- The latch itself is the free root rigid body. -->
  <link name="latch">
    <visual>
      <origin xyz="0.115 0.159 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../objects/Thinkpad_battery_release.stl" scale="0.005 0.005 0.005"/>
      </geometry>
      <material name="green"><color rgba="0.05 0.95 0.12 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0215" rpy="0 0 0"/>
      <geometry><box size="0.040 0.074 0.043"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- Compatibility DOFs: locked, massless-looking, and unrelated to latch motion. -->
  <link name="slider_dummy">
    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
  </link>
  <joint name="latch_slide" type="prismatic">
    <parent link="latch"/><child link="slider_dummy"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.001" effort="1" velocity="0.01"/>
  </joint>

  <link name="lift_dummy">
    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
  </link>
  <joint name="latch_lift" type="prismatic">
    <parent link="slider_dummy"/><child link="lift_dummy"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.001" effort="1" velocity="0.01"/>
  </joint>
</robot>
